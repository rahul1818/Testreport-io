{
  "name": "testreport.io-io",
  "version": "1.0.6",
  "description": "Playwright HTML test report dashboard and custom reporter — live viewer, flaky tests, PDF/Excel export, and analytics",
  "main": "index.js",
  "bin": {
    "playwright-viewer": "bin/playwright-viewer"
  },
  "exports": {
    ".": "./index.js",
    "./reporter": "./lib/reporter.js",
    "./viewer": "./lib/viewer.js"
  },
  "files": [
    "lib",
    "bin",
    "index.js",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "keywords": [
    "playwright",
    "playwright-report",
    "playwright-reporter",
    "playwright-html-report",
    "report",
    "reporter",
    "html",
    "test",
    "testing",
    "testops",
    "test-reports",
    "dashboard",
    "e2e",
    "automation",
    "flaky",
    "ci"
  ],
  "author": "Rahul Sharma <rahul_sharma1818@yahoo.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahul1818/Testreport-io.git"
  },
  "bugs": {
    "url": "https://github.com/rahul1818/Testreport-io/issues"
  },
  "homepage": "https://github.com/rahul1818/Testreport-io#readme",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "Playwright test report viewer",
    "vendor:jspdf": "node -e \"require('fs').copyFileSync(require('path').join('node_modules','jspdf','dist','jspdf.umd.min.js'), require('path').join('assets','jspdf.umd.min.js'))\""
  },
  "devDependencies": {
    "jspdf": "^4.2.1"
  }
}
